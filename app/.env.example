# Copy to .env.local for local dev against a real server (npm run dev in ../server).
# Leave VITE_API_BASE_URL unset in production if the API server serves this
# app's build output itself (see server/README.md) — requests will just use
# relative /api paths, same origin, no CORS.
VITE_API_BASE_URL=http://localhost:4100
VITE_API_TOKEN=dev-local-token
